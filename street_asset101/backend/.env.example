# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/street_light_db?schema=public"

# JWT
JWT_SECRET="change-this-secret"
JWT_REFRESH_SECRET="change-this-refresh-secret"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Server
PORT=4000
NODE_ENV=development

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limit
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SMS
SMS_API_KEY=
SMS_API_URL=

# GIS
GIS_DEFAULT_CENTER="9.0243,38.7468"
GIS_DEFAULT_ZOOM=12
