# Compose environment variables for both backend and frontend

# Database connection used by backend service
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/street_light_db?schema=public"

# JWT secrets for backend
JWT_SECRET="super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-in-production"

# Backend service port
PORT=4000

# CORS origin for backend API
CORS_ORIGIN="http://localhost:3000"

# Frontend API URL
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# For remote deployment on Ubuntu server at 192.168.213.128, override these values:
# CORS_ORIGIN="http://192.168.213.128"
# NEXT_PUBLIC_API_URL="http://192.168.213.128/api/v1"
